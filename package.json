{
  "name": "prettier-plugin-craft-twig",
  "version": "1.0.0",
  "description": "Prettier Craft CMS Twig/HTML plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanleichty/prettier-plugin-craft-twig.git"
  },
  "author": "Ryan Leichty <ryan.leichty@gmail.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/ryanleichty/prettier-plugin-craft-twig",
  "bugs": {
    "url": "https://github.com/ryanleichty/prettier-plugin-craft-twig/issues"
  },
  "files": [
    "grammar/*",
    "dist/**/*.js",
    "dist/**/*.ts",
    "standalone.js",
    "standalone.d.ts",
    "ThirdPartyNotices.txt"
  ],
  "scripts": {
    "build": "yarn build:shims && yarn build:ts && yarn build:standalone",
    "build:shims": "node build/shims.js",
    "build:standalone": "vite build && node build/move-standalone.js",
    "build:ts": "node build/clean-dist.js && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "coverage": "vitest run --coverage",
    "coverage:json": "vitest run --coverage --coverage.reporter=json",
    "coverage:lcov": "vitest run --coverage --coverage.reporter=lcov",
    "debug": "vitest --inspect-brk --no-file-parallelism",
    "format": "scripts/relative-to-alias && prettier --write --ignore-unknown \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check --ignore-unknown \"{src,test}/**/*.ts\"",
    "playground": "npx http-server playground",
    "prepare": "husky install",
    "prerelease": "scripts/prerelease",
    "prettier": "scripts/prettier",
    "prettier2": "cross-env PRETTIER_MAJOR=2 scripts/prettier",
    "prettier3": "cross-env PRETTIER_MAJOR=3 scripts/prettier",
    "test": "vitest run",
    "test:3": "cross-env PRETTIER_MAJOR=3 vitest run",
    "test:idempotence": "cross-env TEST_IDEMPOTENCE=true vitest run",
    "test:idempotence:3": "cross-env PRETTIER_MAJOR=3 yarn test:idempotence",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "prettier": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@tsconfig/node14": "^1.0.1",
    "@types/line-column": "^1.0.0",
    "@types/node": "^16.11.11",
    "@types/prettier": "^2.4.2",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^7.0.3",
    "husky": "^7.0.0",
    "prettier2": "npm:prettier@^2.6.1",
    "prettier3": "npm:prettier@^3.0.0",
    "pretty-quick": "^3.1.3",
    "tsc-alias": "^1.6.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "html-styles": "^1.0.0",
    "line-column": "^1.0.2",
    "ohm-js": "^16.3.0"
  },
  "packageManager": "yarn@1.22.21+sha1.1959a18351b811cdeedbd484a8f86c3cc3bbaf72"
}
